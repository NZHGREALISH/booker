# Booking page URL. Use the real booking detail page.
BOOKING_URL=<booking page URL>

# The exact slot text from the button's data-slot-text, for example:
# 8 - 8:50 PM
# 7 - 7:55 AM
TARGET_SLOT=8 - 8:50 PM

# Optional comma-separated priority list. If set, this overrides TARGET_SLOT.
# The first available matching slot wins.
TARGET_SLOTS=8 - 8:50 PM,7 - 7:55 PM,6 - 6:55 PM

# Show an interactive numbered slot menu on startup. Press Enter to use TARGET_SLOTS.
SELECT_SLOTS_MENU=true

# Target date. Prefer YYYY-MM-DD. TARGET_DATE_TEXT is used as fallback.
TARGET_DATE=2026-06-16
TARGET_DATE_TEXT=Jun 16, 2026

# Show an interactive Today/Tomorrow/Day-after-tomorrow menu on startup.
SELECT_DATE_MENU=true

# Comma-separated court tabs. The script opens one tab per court and stops all
# workers after the first successful click.
TARGET_FACILITIES=Court 01-AC-Badminton,Court 02-AC-Badminton,Court 03-AC-Badminton

# Used by npm run test:click. Defaults to TARGET_SLOT/TARGET_DATE if blank.
TEST_FACILITY=Court 03-AC-Badminton
TEST_SLOT=
TEST_SLOTS=
TEST_DATE=
TEST_DATE_TEXT=

# Show an interactive polling start menu:
# 1. Start now
# 2. Start N seconds before selected date/time opens
SELECT_POLLING_MENU=true
BOOKING_OPENS_HOURS=48
POLLING_LEAD_SECONDS=5

# Used only when SELECT_POLLING_MENU=false. Leave blank to start immediately.
# Format: HH:mm:ss, using your computer's local timezone.
START_AT=

# How often to refresh while waiting.
REFRESH_MS=650

# Stop after this many seconds if the slot never appears.
TIMEOUT_SECONDS=180

# Keep looping until a booking success alert appears. If false, TIMEOUT_SECONDS applies.
LOOP_UNTIL_SUCCESS=true

# After clicking Book Now, wait this long for success/failure/captcha completion.
BOOKING_RESULT_TIMEOUT_MS=120000

# persistent: Playwright opens a visible browser profile.
# cdp: connect to Chrome started with --remote-debugging-port=9222.
BOOKER_MODE=persistent

# Used only in cdp mode.
CDP_URL=http://127.0.0.1:9222

# Used by npm run start:default-chrome. Chrome requires a non-default profile
# for remote debugging, so this profile persists your booking login after one setup.
CHROME_USER_DATA_DIR=.chrome-debug-profile

# Used only in persistent mode. Keeps your login session between runs.
USER_DATA_DIR=.browser-profile
