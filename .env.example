# Booking page URL. Use the real recreation.utoronto.ca booking detail page.
BOOKING_URL=https://recreation.utoronto.ca/booking/33215bab-05b9-41de-be04-c9ae496d5609

# The exact slot text from the button's data-slot-text, for example:
# 8 - 8:55 PM
# 7 - 7:55 AM
TARGET_SLOT=8 - 8:55 PM

# Optional. Click a facility tab by visible text before polling.
# Leave blank if you already selected it manually.
TARGET_FACILITY=

# Local time to start active polling. Leave blank to start immediately.
# Format: HH:mm:ss, using your computer's local timezone.
START_AT=19:59:55

# How often to refresh while waiting.
REFRESH_MS=650

# Stop after this many seconds if the slot never appears.
TIMEOUT_SECONDS=180

# persistent: Playwright opens a visible browser profile.
# cdp: connect to Chrome started with --remote-debugging-port=9222.
BOOKER_MODE=persistent

# Used only in cdp mode.
CDP_URL=http://127.0.0.1:9222

# Used only in persistent mode. Keeps your login session between runs.
USER_DATA_DIR=.browser-profile
